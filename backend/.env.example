# ── LLM (ByteDance ARK API) ───────────────────────────────────────────────────
ARK_API_KEY=your_api_key_here
ARK_MODEL_ID=ep-20250211103006-s67q4

# ── RAG — Embedding Backend ───────────────────────────────────────────────────
# Provider: huggingface (default, local, ~90MB) | openai | ark
EMBEDDING_PROVIDER=huggingface
# Model name (provider-specific):
#   huggingface: BAAI/bge-small-zh-v1.5  (default)
#   openai:      text-embedding-3-small
#   ark:         doubao-embedding-large-text-240915
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── RAG — Vector Store Backend ────────────────────────────────────────────────
# Backend: chroma (default) | faiss | qdrant | pgvector
VECTOR_STORE=chroma

# Chroma (default — file-based, no server required)
CHROMA_PERSIST_DIR=rag/chroma_db

# FAISS (in-memory + disk, fast, no server)
# VECTOR_STORE=faiss
# FAISS_INDEX_PATH=rag/faiss_index

# Qdrant (production-grade, requires Qdrant server)
# VECTOR_STORE=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# pgvector (PostgreSQL extension)
# VECTOR_STORE=pgvector
# PGVECTOR_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# ── Observability — LangSmith (optional) ─────────────────────────────────────
# Best Practice (LangChain Architecture): enables tracing of all LLM calls,
# tool invocations, and agent state transitions for debugging and monitoring.
# Sign up at https://smith.langchain.com/ and set your API key to enable.
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=bigh-health-assistant
# LANGCHAIN_TRACING_V2=true
